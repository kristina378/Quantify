@{
    ViewData["Title"] = "Registration";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p style="font-size: 20px;">Create your new account in Quantify.</p>
</div>

<div class="text-center mb-5">
    <h4 class="mb-3">Choose account type</h4>
    <div class="d-flex justify-content-center gap-3">
        <a asp-action="RegisterStudent" class="btn btn-primary">Student</a>
        <a asp-action="RegisterTutor" class="btn btn-primary">Tutor</a>
    </div>
</div>
