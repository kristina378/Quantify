@using Quantify.Core.Users
@{
    string userRole;
    string action = string.Empty;
    if(User.Identity?.IsAuthenticated == true){

        if(User.IsInRole("Tutor")){
            userRole = "Tutor";
            action = "EditTutor";
        }
        else if(User.IsInRole("Student")){
            userRole = "Student";
            action = "EditStudent";
        }
        else{
            userRole = "Developer";
            action = "EditAdmin";
        }
    }
    else{
        userRole = "Guest";
    }

}

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quantify</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
            <div class="container">
                @if(User.Identity?.IsAuthenticated == false){
                    <a class="navbar-brand" href="/">Quantify @userRole</a>
                    <div class="collapse navbar-collapse d-flex justify-content-end">
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <a class="nav-link" href="/Account/Login">Zaloguj</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="/Account/Register">Zarejestruj</a>
                            </li>
                        </ul>
                    </div>
                }
               else{
                        <a class="navbar-brand" href="/">Quantify @userRole</a>
                        <div class="collapse navbar-collapse d-flex justify-content-end">
                            <ul class="navbar-nav">
                                <li class="nav-item d-flex align-items-center">
                                    <span class="navbar-text me-3">Cześć @User.Identity?.Name!</span>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Profile" asp-action="@action">Mój profil</a>
                                </li>
                                <li>
                                    <form method="post" asp-controller="Account" asp-action="Logout">
                                        <button type="submit" class="btn btn-outline-danger btn-sm ms-2">Wyloguj</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                }
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted text-center mt-5 py-3">
        <div class="container">
            &copy; 2026 - Quantify
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>